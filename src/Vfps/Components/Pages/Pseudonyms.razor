@page "/ui/namespaces/{NamespaceName}/pseudonyms"
@rendermode InteractiveServer
@inject IPseudonymAppService PseudonymAppService

<PageTitle>Pseudonyms - @NamespaceName</PageTitle>

<div class="mx-auto max-w-5xl space-y-6">
    <div>
        <BbButton Variant="ButtonVariant.Link" Href="/ui/namespaces" Class="px-0">
            <LucideIcon Name="arrow-left" Size="16" />
            Back to namespaces
        </BbButton>
        <div class="flex items-center gap-2">
            <LucideIcon Name="key-round" Size="24" Class="text-primary" />
            <h1 class="text-2xl font-semibold tracking-tight">Pseudonyms in @NamespaceName</h1>
        </div>
    </div>

    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Reverse lookup</BbCardTitle>
            <BbCardDescription>
                Reveals the original value for one pseudonym. This is a separate, more
                tightly-gated, audited action - it is never shown in the table below.
            </BbCardDescription>
        </BbCardHeader>
        <BbCardContent Class="space-y-3">
            <div class="flex flex-wrap items-end gap-2">
                <BbField Class="w-full max-w-sm">
                    <BbFieldLabel For="lookupValue">Pseudonym value</BbFieldLabel>
                    <BbFieldContent>
                        <BbInput @bind-Value="_lookupValue" Id="lookupValue" />
                    </BbFieldContent>
                </BbField>
                <BbButton OnClick="ReverseLookupAsync" Loading="_isLookingUp">Look up</BbButton>
            </div>
            @if (_lookupError is not null)
            {
                <BbAlert Variant="AlertVariant.Danger">
                    <BbAlertDescription>@_lookupError</BbAlertDescription>
                </BbAlert>
            }
            @if (_lookupResult is not null)
            {
                <p class="text-sm">
                    Original value: <code class="rounded bg-muted px-1.5 py-0.5">@_lookupResult.OriginalValue</code>
                </p>
            }
        </BbCardContent>
    </BbCard>

    @if (_errorMessage is not null)
    {
        <BbAlert Variant="AlertVariant.Danger">
            <BbAlertTitle>Could not load pseudonyms</BbAlertTitle>
            <BbAlertDescription>@_errorMessage</BbAlertDescription>
        </BbAlert>
    }
    else
    {
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Pseudonyms</BbCardTitle>
            </BbCardHeader>
            <BbCardContent>
                <BbDataGrid Items="@_items" ShowPagination="false" IsLoading="@_isLoading">
                    <Columns>
                        <BbDataGridPropertyColumn Property="@(p => p.PseudonymValue)" Title="Pseudonym" />
                        <BbDataGridPropertyColumn
                            Property="@(p => p.CreatedAt)"
                            Title="Created at"
                            Format="yyyy-MM-dd HH:mm:ss"
                        />
                        <BbDataGridPropertyColumn
                            Property="@(p => p.LastUpdatedAt)"
                            Title="Last updated"
                            Format="yyyy-MM-dd HH:mm:ss"
                        />
                    </Columns>
                </BbDataGrid>

                <div class="mt-4 flex gap-2">
                    <BbButton
                        Variant="ButtonVariant.Outline"
                        OnClick="GoToPreviousPageAsync"
                        Disabled="@(_pageTokenStack.Count == 0 || _isLoading)"
                    >
                        Previous
                    </BbButton>
                    <BbButton
                        Variant="ButtonVariant.Outline"
                        OnClick="GoToNextPageAsync"
                        Disabled="@(_nextPageToken is null || _isLoading)"
                    >
                        Next
                    </BbButton>
                </div>
            </BbCardContent>
        </BbCard>
    }
</div>

@code {
    private const int PageSize = 25;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    [Parameter]
    public string NamespaceName { get; set; } = string.Empty;

    private IReadOnlyList<PseudonymSummaryDto> _items = [];
    private string? _currentPageToken;
    private string? _nextPageToken;
    private readonly Stack<string?> _pageTokenStack = new();
    private bool _isLoading;
    private string? _errorMessage;

    private string _lookupValue = string.Empty;
    private bool _isLookingUp;
    private string? _lookupError;
    private Vfps.Data.Models.Pseudonym? _lookupResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync(null);
    }

    private async Task<ClaimsPrincipal> GetUserAsync() =>
        AuthenticationState is null ? new ClaimsPrincipal() : (await AuthenticationState).User;

    private async Task LoadPageAsync(string? pageToken)
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            var user = await GetUserAsync();
            var page = await PseudonymAppService.ListAsync(
                NamespaceName,
                PageSize,
                pageToken,
                includeTotalSize: false,
                user,
                CancellationToken.None
            );
            _items = page.Items;
            _nextPageToken = page.NextPageToken;
            _currentPageToken = pageToken;
        }
        catch (NamespaceNotFoundException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (ForbiddenException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ReverseLookupAsync()
    {
        _isLookingUp = true;
        _lookupError = null;
        _lookupResult = null;
        try
        {
            var user = await GetUserAsync();
            _lookupResult = await PseudonymAppService.ReverseLookupAsync(
                NamespaceName,
                _lookupValue,
                user,
                CancellationToken.None
            );
            if (_lookupResult is null)
            {
                _lookupError = $"No pseudonym '{_lookupValue}' found in namespace '{NamespaceName}'.";
            }
        }
        catch (ForbiddenException ex)
        {
            _lookupError = ex.Message;
        }
        finally
        {
            _isLookingUp = false;
        }
    }

    private async Task GoToNextPageAsync()
    {
        if (_nextPageToken is null)
        {
            return;
        }

        _pageTokenStack.Push(_currentPageToken);
        await LoadPageAsync(_nextPageToken);
    }

    private async Task GoToPreviousPageAsync()
    {
        if (_pageTokenStack.Count == 0)
        {
            return;
        }

        var previousToken = _pageTokenStack.Pop();
        await LoadPageAsync(previousToken);
    }
}
