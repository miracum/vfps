@page "/namespaces/{NamespaceName}/pseudonyms"
@rendermode InteractiveServer
@inject IPseudonymAppService PseudonymAppService

<PageTitle>Pseudonyms - @NamespaceName</PageTitle>

<div class="mx-auto max-w-5xl space-y-6">
    <div>
        <BbButton Variant="ButtonVariant.Link" Href="/ui/namespaces" Class="px-0">
            <LucideIcon Name="arrow-left" Size="16" />
            Back to namespaces
        </BbButton>
        <div class="flex items-center gap-2">
            <LucideIcon Name="key-round" Size="24" Class="text-primary" />
            <h1 class="text-2xl font-semibold tracking-tight">Pseudonyms in @NamespaceName</h1>
        </div>
    </div>

    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Create pseudonym</BbCardTitle>
        </BbCardHeader>
        <BbCardContent Class="space-y-3">
            <div class="flex flex-wrap items-end gap-2">
                <BbField Class="w-full max-w-sm">
                    <BbFieldLabel For="originalValue">Original value</BbFieldLabel>
                    <BbFieldContent>
                        <BbInput @bind-Value="_createValue" Id="originalValue" />
                    </BbFieldContent>
                </BbField>
                <BbButton OnClick="CreatePseudonymAsync" Loading="_isCreating">Create</BbButton>
            </div>
            @if (_createError is not null)
            {
                <BbAlert Variant="AlertVariant.Danger">
                    <BbAlertDescription>@_createError</BbAlertDescription>
                </BbAlert>
            }
            @if (_createResult is not null)
            {
                <p class="text-sm">
                    Pseudonym: <code class="rounded bg-muted px-1.5 py-0.5">@_createResult.PseudonymValue</code>
                </p>
            }
        </BbCardContent>
    </BbCard>

    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Reverse lookup</BbCardTitle>
            <BbCardDescription>
                Reveals the original value for one pseudonym. This is a separate, more
                tightly-gated, audited action - it is never shown in the table below.
            </BbCardDescription>
        </BbCardHeader>
        <BbCardContent Class="space-y-3">
            <div class="flex flex-wrap items-end gap-2">
                <BbField Class="w-full max-w-sm">
                    <BbFieldLabel For="lookupValue">Pseudonym value</BbFieldLabel>
                    <BbFieldContent>
                        <BbInput @bind-Value="_lookupValue" Id="lookupValue" />
                    </BbFieldContent>
                </BbField>
                <BbButton OnClick="ReverseLookupAsync" Loading="_isLookingUp">Look up</BbButton>
            </div>
            @if (_lookupError is not null)
            {
                <BbAlert Variant="AlertVariant.Danger">
                    <BbAlertDescription>@_lookupError</BbAlertDescription>
                </BbAlert>
            }
            @if (_lookupResult is not null)
            {
                <p class="text-sm">
                    Original value: <code class="rounded bg-muted px-1.5 py-0.5">@_lookupResult.OriginalValue</code>
                </p>
            }
        </BbCardContent>
    </BbCard>

    @if (_errorMessage is not null)
    {
        <BbAlert Variant="AlertVariant.Danger">
            <BbAlertTitle>Could not load pseudonyms</BbAlertTitle>
            <BbAlertDescription>@_errorMessage</BbAlertDescription>
        </BbAlert>
    }
    else
    {
        <BbCard>
            <BbCardHeader>
                <BbCardTitle>Pseudonyms</BbCardTitle>
            </BbCardHeader>
            <BbCardContent>
                <BbDataGrid Items="@_items" ShowPagination="false" IsLoading="@_isLoading">
                    <Columns>
                        <BbDataGridPropertyColumn Property="@(p => p.PseudonymValue)" Title="Pseudonym" />
                        <BbDataGridTemplateColumn Title="Original value">
                            <ChildContent Context="p">
                                @if (_revealedValues.TryGetValue(p.PseudonymValue, out var revealed))
                                {
                                    <code class="rounded bg-muted px-1.5 py-0.5 text-xs">@revealed</code>
                                }
                                else
                                {
                                    <BbButton
                                        Variant="ButtonVariant.Ghost"
                                        Size="ButtonSize.Icon"
                                        OnClick="() => RevealAsync(p.PseudonymValue)"
                                        Loading="@_revealingValues.Contains(p.PseudonymValue)"
                                        AriaLabel="Reveal original value"
                                    >
                                        <LucideIcon Name="eye" Size="16" />
                                    </BbButton>
                                    @if (_revealErrors.TryGetValue(p.PseudonymValue, out var revealError))
                                    {
                                        <p class="mt-1 text-xs text-destructive">@revealError</p>
                                    }
                                }
                            </ChildContent>
                        </BbDataGridTemplateColumn>
                        <BbDataGridPropertyColumn
                            Property="@(p => p.CreatedAt)"
                            Title="Created at"
                            Format="yyyy-MM-dd HH:mm:ss"
                        />
                        <BbDataGridPropertyColumn
                            Property="@(p => p.LastUpdatedAt)"
                            Title="Last updated"
                            Format="yyyy-MM-dd HH:mm:ss"
                        />
                    </Columns>
                </BbDataGrid>

                <div class="mt-4 flex gap-2">
                    <BbButton
                        Variant="ButtonVariant.Outline"
                        OnClick="GoToPreviousPageAsync"
                        Disabled="@(_pageTokenStack.Count == 0 || _isLoading)"
                    >
                        Previous
                    </BbButton>
                    <BbButton
                        Variant="ButtonVariant.Outline"
                        OnClick="GoToNextPageAsync"
                        Disabled="@(_nextPageToken is null || _isLoading)"
                    >
                        Next
                    </BbButton>
                </div>
            </BbCardContent>
        </BbCard>
    }
</div>

@code {
    private const int PageSize = 25;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    [Parameter]
    public string NamespaceName { get; set; } = string.Empty;

    private IReadOnlyList<PseudonymSummaryDto> _items = [];
    private string? _currentPageToken;
    private string? _nextPageToken;
    private readonly Stack<string?> _pageTokenStack = new();
    private bool _isLoading;
    private string? _errorMessage;

    private string _lookupValue = string.Empty;
    private bool _isLookingUp;
    private string? _lookupError;
    private Vfps.Data.Models.Pseudonym? _lookupResult;

    private string _createValue = string.Empty;
    private bool _isCreating;
    private string? _createError;
    private Vfps.Data.Models.Pseudonym? _createResult;

    // Per-row reveal state for the pseudonym list, keyed by pseudonym value - independent of the
    // single reverse-lookup textbox above, and independent per row so revealing one row doesn't
    // block revealing another.
    private readonly HashSet<string> _revealingValues = [];
    private readonly Dictionary<string, string> _revealedValues = [];
    private readonly Dictionary<string, string> _revealErrors = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync(null);
    }

    private async Task<ClaimsPrincipal> GetUserAsync() =>
        AuthenticationState is null ? new ClaimsPrincipal() : (await AuthenticationState).User;

    private async Task LoadPageAsync(string? pageToken)
    {
        // Guards against re-entrant invocation - see the identical comment on
        // Namespaces.razor's CreateNamespaceAsync for why this matters under Blazor Server.
        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        _errorMessage = null;
        try
        {
            var user = await GetUserAsync();
            var page = await PseudonymAppService.ListAsync(
                NamespaceName,
                PageSize,
                pageToken,
                includeTotalSize: false,
                user,
                CancellationToken.None
            );
            _items = page.Items;
            _nextPageToken = page.NextPageToken;
            _currentPageToken = pageToken;
        }
        catch (NamespaceNotFoundException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (ForbiddenException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreatePseudonymAsync()
    {
        // Guards against re-entrant invocation - see the identical comment on
        // Namespaces.razor's CreateNamespaceAsync for why this matters under Blazor Server.
        if (_isCreating)
        {
            return;
        }

        _isCreating = true;
        _createError = null;
        _createResult = null;
        try
        {
            var user = await GetUserAsync();
            _createResult = await PseudonymAppService.CreateAsync(
                NamespaceName,
                _createValue,
                user,
                CancellationToken.None
            );
            _createValue = string.Empty;

            // Newest pseudonyms sort first, so jump back to the first page to show it.
            _pageTokenStack.Clear();
            await LoadPageAsync(null);
        }
        catch (NamespaceNotFoundException ex)
        {
            _createError = ex.Message;
        }
        catch (PseudonymUpsertFailedException ex)
        {
            _createError = ex.Message;
        }
        catch (ForbiddenException ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task ReverseLookupAsync()
    {
        // Guards against re-entrant invocation - see the identical comment on
        // Namespaces.razor's CreateNamespaceAsync for why this matters under Blazor Server.
        if (_isLookingUp)
        {
            return;
        }

        _isLookingUp = true;
        _lookupError = null;
        _lookupResult = null;
        try
        {
            var user = await GetUserAsync();
            _lookupResult = await PseudonymAppService.ReverseLookupAsync(
                NamespaceName,
                _lookupValue,
                user,
                CancellationToken.None
            );
            if (_lookupResult is null)
            {
                _lookupError = $"No pseudonym '{_lookupValue}' found in namespace '{NamespaceName}'.";
            }
        }
        catch (ForbiddenException ex)
        {
            _lookupError = ex.Message;
        }
        finally
        {
            _isLookingUp = false;
        }
    }

    private async Task RevealAsync(string pseudonymValue)
    {
        // Per-row guard, not the single _isLookingUp flag - HashSet.Add returns false if a
        // reveal for this exact row is already in flight, without blocking other rows.
        if (!_revealingValues.Add(pseudonymValue))
        {
            return;
        }

        _revealErrors.Remove(pseudonymValue);
        try
        {
            var user = await GetUserAsync();
            var result = await PseudonymAppService.ReverseLookupAsync(
                NamespaceName,
                pseudonymValue,
                user,
                CancellationToken.None
            );
            if (result is null)
            {
                _revealErrors[pseudonymValue] = "Not found.";
            }
            else
            {
                _revealedValues[pseudonymValue] = result.OriginalValue;
            }
        }
        catch (ForbiddenException ex)
        {
            _revealErrors[pseudonymValue] = ex.Message;
        }
        finally
        {
            _revealingValues.Remove(pseudonymValue);
        }
    }

    private async Task GoToNextPageAsync()
    {
        if (_nextPageToken is null)
        {
            return;
        }

        _pageTokenStack.Push(_currentPageToken);
        await LoadPageAsync(_nextPageToken);
    }

    private async Task GoToPreviousPageAsync()
    {
        if (_pageTokenStack.Count == 0)
        {
            return;
        }

        var previousToken = _pageTokenStack.Pop();
        await LoadPageAsync(previousToken);
    }
}
