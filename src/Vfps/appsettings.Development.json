{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=127.0.0.1:35432;Username=postgres;Password=postgres;Database=vfps;Timeout=60;Max Auto Prepare=5;Maximum Pool Size=50"
  },
  "Authorization": {
    "IsEnabled": true,
    "Authority": "http://localhost:8180/realms/vfps",
    "ClientId": "vfps-web",
    "ClientSecret": "vfps-web-secret",
    "AdminRoles": ["vfps-admin"],
    "NamespaceRules": [
      {
        "Namespace": "development",
        "ReadRoles": ["vfps-ns-development-read"],
        "WriteRoles": ["vfps-ns-development-read"],
        "ReverseLookupRoles": ["vfps-ns-development-read"]
      }
    ]
  },
  "S3": {
    "IsEnabled": true,
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "vfps",
    "SecretKey": "vfps-minio-secret",
    "Bucket": "vfps-csv-jobs",
    "ForcePathStyle": true,
    "AllowedOrigins": ["http://localhost:8080"]
  },
  "Pseudonymization": {
    "Caching": {
      "Namespaces": {
        "IsEnabled": true
      },
      "Pseudonyms": {
        "IsEnabled": false
      }
    }
  },
  "Tracing": {
    "IsEnabled": true,
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Init": {
    "v1": {
      "Namespaces": [
        {
          "Name": "development",
          "Description": "auto-generated namespace for development",
          "PseudonymGenerationMethod": "SecureRandomBase64UrlEncoded",
          "PseudonymLength": 16,
          "PseudonymPrefix": "dev-"
        }
      ]
    }
  }
}
