{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    },
    "Endpoints": {
      "Http": {
        "Protocols": "Http1AndHttp2AndHttp3",
        "Url": "http://0.0.0.0:8080"
      },
      "HttpGrpc": {
        "Protocols": "Http2",
        "Url": "http://0.0.0.0:8081"
      }
    }
  },
  "ConnectionStrings": {
    "PostgreSQL": ""
  },
  "Authorization": {
    "IsEnabled": false,
    "Authority": "",
    "Audience": "",
    "ClientId": "",
    "ClientSecret": "",
    "RoleClaimType": "roles",
    "AdminRoles": [],
    "NamespaceRules": []
  },
  "S3": {
    "IsEnabled": false,
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "",
    "Region": "eu-central-1",
    "ForcePathStyle": true,
    "PresignedUrlExpiry": "0.00:15:00",
    "AllowedOrigins": []
  },
  "Pseudonymization": {
    "BackingStore": "PostgreSQL",
    "Caching": {
      "Namespaces": {
        "IsEnabled": false
      },
      "Pseudonyms": {
        "IsEnabled": false
      },
      "SizeLimit": 65534,
      "AbsoluteExpiration": "0.01:00:00"
    }
  },
  "ForceRunDatabaseMigrations": false,
  "Tracing": {
    "IsEnabled": false,
    "ServiceName": "vfps",
    "RootSampler": "AlwaysOnSampler",
    "SamplingProbability": 0.1,
    "Otlp": {
      "Endpoint": ""
    }
  },
  "MetricsPort": 8082
}
