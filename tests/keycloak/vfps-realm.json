{
  "realm": "vfps",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "vfps-web",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "vfps-web-secret",
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["http://localhost:8080"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "vfps-admin" },
      { "name": "vfps-ns-development-read" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@vfps.example",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["vfps-admin"]
    },
    {
      "username": "reader",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Reader",
      "lastName": "User",
      "email": "reader@vfps.example",
      "credentials": [{ "type": "password", "value": "reader", "temporary": false }],
      "realmRoles": ["vfps-ns-development-read"]
    }
  ]
}
